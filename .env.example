# Copia este archivo como .env y rellena tus credenciales.
# El archivo .env NUNCA debe commitearse al repositorio.
# Obtén tu clave en https://www.firecrawl.dev

# Clave de API de Firecrawl (requerida para búsquedas web avanzadas)
FIRECRAWL_API_KEY=fc-TU_CLAVE_AQUI

# Secreto de firma de webhooks de Firecrawl (opcional).
# Se usa para verificar que las peticiones entrantes de webhook provienen
# realmente de Firecrawl. Consulta la sección "Webhooks" en tu panel.
# NUNCA compartas ni confirmes este valor en el repositorio.
FIRECRAWL_WEBHOOK_SECRET=TU_SECRETO_WEBHOOK_AQUI
